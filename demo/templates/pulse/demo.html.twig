{% extends 'base.html.twig' %}

{% block title %}Pulse — den 14{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% if not vite_dev() %}
        {% for href in vite_css('vite-entry.ts') %}
            <link rel="stylesheet" href="{{ href }}">
        {% endfor %}
    {% endif %}
{% endblock %}

{% block javascripts %}
    {% if vite_dev() %}
        <script type="module" src="http://localhost:5173/@vite/client"></script>
        <script type="module" src="{{ vite_js('vite-entry.ts') }}"></script>
    {% else %}
        <script type="module" src="{{ vite_js('vite-entry.ts') }}"></script>
    {% endif %}
{% endblock %}

{% block body %}
    <p style="max-width:960px;margin:0.75rem auto;font-family:system-ui,sans-serif;">
        <a href="{{ path('app_home') }}">← Home</a>
        · Den 14 finální demo
    </p>
    <div
        id="vue-pulse-app"
        data-login-url="{{ path('api_login') }}"
        data-orders-url="{{ path('api_pulse_orders_list') }}"
    ></div>
{% endblock %}
