{% extends 'base.html.twig' %}

{% block title %}Nový topic{% endblock %}

{% block body %}
    <main style="max-width: 720px; margin: 2rem auto; font-family: system-ui, sans-serif;">
        <h1>Nový study topic</h1>
        <form method="post">
            <p>
                <label>Den č.<br>
                    <input type="number" name="day" value="{{ defaultDay }}" min="1" max="14">
                </label>
            </p>
            <p>
                <label>Název<br>
                    <input type="text" name="title" required style="width: 100%;">
                </label>
            </p>
            <p>
                <label>Popis<br>
                    <textarea name="body" rows="5" required style="width: 100%;"></textarea>
                </label>
            </p>
            <button type="submit">Uložit</button>
        </form>
        <p><a href="{{ path('app_topics_index') }}">← zpět</a></p>
    </main>
{% endblock %}
